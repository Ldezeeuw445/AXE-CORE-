# AXE Core API — VPS environment (deploy.sh copies this to .env)
# Fill in real values, then: nano /opt/axe-core-api/.env

# Bearer token the frontend's server-side proxy sends as Authorization: Bearer <this>
# (set as AXE_CORE_API_KEY — NOT VITE_AXE_CORE_API_KEY — in Vercel project settings)
AXE_API_KEY=

SUPABASE_URL=https://pqnngpcgbdwxavbatbia.supabase.co
# service_role key (Settings -> API in the Supabase dashboard) — bypasses RLS, keep secret
SUPABASE_SERVICE_ROLE=

# Optional — only needed for the /n8n/* routes
N8N_URL=http://localhost:5678
N8N_API_KEY=

# Optional — only needed for the /github/* routes
GITHUB_TOKEN=

# Comma-separated, no spaces. Add every origin that will actually call this API:
# the Vercel production domain, any custom domain once DNS points here, and
# localhost for local dev. A domain NOT in this list gets a browser CORS
# error, not a 404 — that's the #1 cause of "it randomly stopped working"
# every time this app's frontend has moved between hosts.
ALLOWED_ORIGINS=https://axe-core-rust.vercel.app,http://localhost:5173

# Used by crew_runner.py to invoke the isolated CrewAI venv (see requirements_crew.txt)
CREW_VENV_PY=/opt/axe-crew-venv/bin/python3
CREW_TIMEOUT=600
