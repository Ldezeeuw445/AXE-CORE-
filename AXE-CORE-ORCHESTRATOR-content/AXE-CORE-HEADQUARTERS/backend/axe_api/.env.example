# AXE Core API — VPS environment (deploy.sh copies this to .env)
# Fill in real values, then: nano /opt/axe-core-api/.env

# Bearer token the frontend's server-side proxy sends as Authorization: Bearer <this>
# (set as AXE_CORE_API_KEY — NOT VITE_AXE_CORE_API_KEY — in Vercel project settings)
AXE_API_KEY=

SUPABASE_URL=https://pqnngpcgbdwxavbatbia.supabase.co
# service_role key (Settings -> API in the Supabase dashboard) — bypasses RLS, keep secret
SUPABASE_SERVICE_ROLE=

# Optional — only needed for the /n8n/* routes
N8N_URL=http://localhost:5678
N8N_API_KEY=

# Optional — only needed for the /github/* routes
GITHUB_TOKEN=

# Optional — only needed for the /vercel/* routes. Token: Vercel dashboard ->
# Settings -> Tokens (scope it to just this project if possible). Project ID:
# the project's Settings -> General page. Team ID only needed if the project
# lives under a team, not a personal account.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Comma-separated, no spaces. Add every origin that will actually call this API:
# the Vercel production domain, any custom domain once DNS points here, and
# localhost for local dev. A domain NOT in this list gets a browser CORS
# error, not a 404 — that's the #1 cause of "it randomly stopped working"
# every time this app's frontend has moved between hosts.
ALLOWED_ORIGINS=https://axe-core-rust.vercel.app,http://localhost:5173

# Used by crew_runner.py to invoke the isolated CrewAI venv (see requirements_crew.txt)
CREW_VENV_PY=/opt/axe-crew-venv/bin/python3
CREW_TIMEOUT=600

# OSINT map data (optional): live global vessel feed via aisstream.io
AISSTREAM_API_KEY=

# Code Editor workspace — the editable file tree the in-app IDE reads/writes.
# Defaults to /opt/axe-workspace (auto-created). Clone your projects into it,
# e.g. `git clone <repo> /opt/axe-workspace/my-app`, and they show up in the
# editor. Every path is confined to this dir (no traversal outside).
WORKSPACE_DIR=/opt/axe-workspace

# Local agent bridges (all optional, all OFF until a URL is set). Point each
# at the tool's real execute endpoint — the FULL url including path — that
# already accepts the payload the app sends. The optional *_API_KEY is sent as
# a Bearer token. Until a URL is set, /internal/{tool}/execute returns a clear
# 503 "not configured" instead of a dead 404 (never a fabricated result).
# Examples (adjust host/port/path to your actual running services):
#   OPENHANDS_URL=http://127.0.0.1:3000/api/conversations
#   HERMES_URL=http://127.0.0.1:11434/v1/chat/completions   # if served via Ollama-compatible API
OPENHANDS_URL=
OPENHANDS_API_KEY=
OPENJARVIS_URL=
OPENJARVIS_API_KEY=
OPENCLAW_URL=
OPENCLAW_API_KEY=
KILOCODE_URL=
KILOCODE_API_KEY=
HERMES_URL=
HERMES_API_KEY=
