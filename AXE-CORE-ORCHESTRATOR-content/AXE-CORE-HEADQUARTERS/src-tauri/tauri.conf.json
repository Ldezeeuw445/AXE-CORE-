{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AXE CORE",
  "version": "1.0.0",
  "identifier": "com.axe.core",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5000",
    "frontendDist": "../dist/public"
  },
  "app": {
    "windows": [
      {
        "title": "AXE CORE",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability for AXE CORE",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-open",
            "http:default",
            "fs:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AXE CORE OS",
    "longDescription": "AXE CORE — AI Operating System with OSINT surveillance, 3D maps, and multi-agent orchestration.",
    "macOS": {
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
